{
  "name": "@hachej/boring-sharepoint",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "SharePoint Office cloud-ref display substrate for boring-ui.",
  "boring": {
    "id": "boring-sharepoint",
    "label": "SharePoint",
    "front": "dist/front/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./front": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "pnpm run typecheck",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "@hachej/boring-workspace": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@hachej/boring-workspace": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.4.0",
    "typescript": "~7.0.2",
    "vitest": "^4.1.9"
  }
}
