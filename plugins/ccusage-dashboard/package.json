      "agent/index.ts"
    ]
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ccusage": "^20.0.17",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0"
  }
}
