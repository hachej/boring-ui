# bv (beads viewer) local config and caches
.bv/

# Dependencies
node_modules/

# Build output
dist/
**/.vite/
*.tsbuildinfo
.tsbuildinfo.*

# Generated app/API bundles and sourcemaps
apps/full-app/api/generated-index.*
apps/full-app/api/index.ts.map
apps/*/api/*.map
packages/cli/public/

# Local harness/package installs copied into package work dirs
packages/*/lib/node_modules/

# Environment
.env
.env.*
!**/.env.example

# Playwright output
apps/boring-macro-v2/workspace/
apps/boring-macro-v2/.eval-venv/
apps/boring-macro-v2/src/plugins/macro/server/sdk/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/server/sdk/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/server/sdk/*.egg-info/
apps/boring-macro-v2/src/plugins/macro/server/sdk/build/
apps/boring-macro-v2/src/plugins/macro/server/transforms/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/server/transforms/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/sdk/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/sdk/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/sdk/*.egg-info/
apps/boring-macro-v2/src/plugins/macro/sdk/build/
apps/boring-macro-v2/src/plugins/macro/transforms/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/transforms/**/*.py[cod]
