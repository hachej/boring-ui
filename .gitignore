# bv (beads viewer) local config and caches
.bv/

# Dependencies
node_modules/

# Build output
dist/
**/.vite/
.logs/
*.tsbuildinfo
.tsbuildinfo.*
*.tgz

# Generated app/API bundles and sourcemaps
apps/full-app/api/generated-index.*
apps/full-app/api/index.ts.map
apps/*/api/*.map
packages/cli/public/

# Local harness/package installs copied into package work dirs
packages/*/lib/node_modules/

# Runtime workspace state generated by agent provisioning
**/.boring-agent/

# Environment
.env
.env.*
!**/.env.example
.vercel/
**/.vercel/

# Playwright output
apps/boring-macro-v2/workspace/
apps/boring-macro-v2/.eval-venv/
apps/boring-macro-v2/src/plugins/macro/server/sdk/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/server/sdk/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/server/sdk/*.egg-info/
apps/boring-macro-v2/src/plugins/macro/server/sdk/build/
apps/boring-macro-v2/src/plugins/macro/server/transforms/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/server/transforms/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/sdk/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/sdk/**/*.py[cod]
apps/boring-macro-v2/src/plugins/macro/sdk/*.egg-info/
apps/boring-macro-v2/src/plugins/macro/sdk/build/
apps/boring-macro-v2/src/plugins/macro/transforms/**/__pycache__/
apps/boring-macro-v2/src/plugins/macro/transforms/**/*.py[cod]
packages/agent/fixtures/provisioning/test-sdk/**/__pycache__/
packages/agent/fixtures/provisioning/test-sdk/**/*.py[cod]
packages/agent/fixtures/provisioning/test-sdk/*.egg-info/
packages/agent/fixtures/provisioning/test-sdk/build/
playwright-report/
test-results/
e2e-artifacts/

# Swarm / review artifacts (local)
.ntm/
.ui-review/
.worktrees-health/
*_review.patch
/pr-review-*.md
/review-*.md
/worker-*.md
/full-pr-final-review/
packages/agent/bench-results/

# Vitest transient transpiled-config artifacts (leaked when a run is interrupted)
**/vitest.config.ts.timestamp-*.mjs
**/vitest.config.js.timestamp-*.mjs
.claude/worktrees/
/.worktrees/

# LLM eval scratch directories (plugins/CSVs created by live-LLM tests)
**/.eval/
packages/workspace/.pi/
packages/workspace/*.csv
packages/workspace/packages/
packages/workspace/plugins/
packages/workspace/src/plugins/eval-*/
# Repo-root .pi/ too — when the agent's cwd resolves to the monorepo root
# instead of the workspace package, eval scratch lands here.
/.pi/

# Per-plugin signature cache written by BoringPluginAssetManager on load —
# read by `boring-ui-plugin verify` to detect server-file drift. Runtime
# state, never checked in.
**/.boring-signature.json

