{
  "name": "workspace-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @boring/workspace build && vite",
    "build": "pnpm --filter @boring/workspace build && vite build",
    "typecheck": "pnpm --filter @boring/workspace build && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@boring/agent": "workspace:*",
    "@boring/workspace": "workspace:*",
    "@duckdb/node-api": "1.5.2-r.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2",
    "vite": "^6.0.0"
  }
}
