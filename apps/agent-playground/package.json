{
  "name": "agent-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Rich standalone playground for @hachej/boring-agent.",
  "scripts": {
    "dev": "pnpm --filter @hachej/boring-agent build:dev && tsx --env-file=.env.local src/server/index.ts",
    "typecheck": "pnpm --filter @hachej/boring-agent build && tsc --noEmit"
  },
  "dependencies": {
    "@hachej/boring-agent": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
