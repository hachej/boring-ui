{
  "name": "agent-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Rich standalone playground for @hachej/boring-agent.",
  "scripts": {
    "dev": "pnpm --filter @hachej/boring-agent build:dev && tsx --env-file=.env.local src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hachej/boring-agent": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^5.7.2",
    "vite": "^6.3.3"
  }
}
