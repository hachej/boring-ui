{
  "name": "@boring/macro",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/dev.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "build:web": "vite build",
    "eval": "tsx eval/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@boring/agent": "workspace:*",
    "@boring/workspace": "workspace:*",
    "@clickhouse/client": "^1.18.2",
    "fastify": "^5.8.4",
    "fastify-raw-body": "^5.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.0",
    "stripe": "^21.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
