{
  "name": "full-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx src/server/main.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck",
    "e2e:smoke": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@boring/agent": "workspace:*",
    "@boring/core": "workspace:*",
    "@boring/workspace": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
