{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"]
  },
  "include": ["src/server/**/*.ts", "src/plugins/**/server.ts", "src/types/**/*.d.ts"],
  "exclude": ["src/front", "node_modules", "dist"]
}
