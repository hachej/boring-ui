{
  "name": "@hachej/boring-sandbox",
  "version": "0.1.84",
  "type": "module",
  "license": "MIT",
  "description": "Sandbox provider contracts and implementations for Boring runtimes.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./providers/runsc": {
      "types": "./dist/providers/runsc/index.d.ts",
      "import": "./dist/providers/runsc/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check:invariants": "node ./scripts/check-invariants.mjs",
    "lint": "pnpm run typecheck && pnpm run check:invariants",
    "qualify:runsc:isolation": "node ./scripts/qualify-runsc-isolation.mjs",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
