{
  "name": "@hachej/boring-sandbox",
  "version": "0.1.90",
  "type": "module",
  "license": "MIT",
  "description": "Sandbox provider contracts and implementations for Boring runtimes.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./providers/direct": {
      "types": "./dist/providers/direct/index.d.ts",
      "import": "./dist/providers/direct/index.js"
    },
    "./providers/bwrap": {
      "types": "./dist/providers/bwrap/index.d.ts",
      "import": "./dist/providers/bwrap/index.js"
    },
    "./providers/node-workspace": {
      "types": "./dist/providers/node-workspace/index.d.ts",
      "import": "./dist/providers/node-workspace/index.js"
    },
    "./providers/vercel-sandbox": {
      "types": "./dist/providers/vercel-sandbox/index.d.ts",
      "import": "./dist/providers/vercel-sandbox/index.js"
    },
    "./providers/runsc": {
      "types": "./dist/providers/runsc/index.d.ts",
      "import": "./dist/providers/runsc/index.js"
    },
    "./providers/remote-worker": {
      "types": "./dist/providers/remote-worker/index.d.ts",
      "import": "./dist/providers/remote-worker/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check:invariants": "node ./scripts/check-invariants.mjs",
    "lint": "pnpm run typecheck && pnpm run check:invariants",
    "qualify:runsc:isolation": "node ./scripts/qualify-runsc-isolation.mjs",
    "qualify:runsc:isolation:docker": "node ./scripts/qualify-docker-runsc-isolation.mjs",
    "qualify:runsc:v3:reference": "node ./scripts/qualify-runsc-v3-reference.mjs",
    "qualify:bundle:build": "node ./scripts/build-qualification-bundle.mjs",
    "qualify:fleet:verify": "node ./scripts/verify-fleet-admission-evidence.mjs",
    "measure:coldstart:latency": "node ./scripts/measure-cold-start-latency.mjs",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@vercel/blob": "^2.5.0",
    "@vercel/sandbox": "2.3.0",
    "chokidar": "^5.0.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@hachej/boring-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
