{
  "name": "@hachej/boring-workspace",
  "version": "0.1.90",
  "type": "module",
  "license": "MIT",
  "description": "Workspace UI, plugin, and bridge package for composing chat, files, catalogs, editors, and app-specific panes.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "files": [
    "dist",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/workspace.d.ts",
      "import": "./dist/workspace.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./testing/e2e": {
      "types": "./dist/testing-e2e.d.ts",
      "import": "./dist/testing-e2e.js"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "import": "./dist/charts.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./bridge-client": {
      "types": "./dist/bridge-client.d.ts",
      "import": "./dist/bridge-client.js"
    },
    "./app/front": {
      "types": "./dist/app-front.d.ts",
      "import": "./dist/app-front.js",
      "default": "./dist/app-front.js"
    },
    "./app/server": {
      "types": "./dist/app-server.d.ts",
      "import": "./dist/app-server.js",
      "default": "./dist/app-server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./runtime-server": {
      "types": "./dist/runtime-server.d.ts",
      "import": "./dist/runtime-server.js",
      "default": "./dist/runtime-server.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./globals.css": "./dist/workspace.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && vite build && node ./scripts/build-workspace-css.mjs && node ./scripts/assert-build-artifacts.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.front.json && tsc --noEmit -p tsconfig.server.json",
    "test": "vitest run",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs",
    "lint:plugin-invariants": "node ./scripts/check-plugin-invariants.mjs",
    "lint": "pnpm run typecheck"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "recharts": "^2.15.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@hachej/boring-agent": "workspace:*",
    "@hachej/boring-bash": "workspace:*",
    "@hachej/boring-sandbox": "workspace:*",
    "@hachej/boring-ui-kit": "workspace:*",
    "@hachej/boring-ui-plugin-cli": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-query": "^5.101.1",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/markdown": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "dnd-core": "^16.0.1",
    "dockview-react": "^7.0.2",
    "fastify": "^5.9.0",
    "jiti": "^2.7.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.21.0",
    "react-arborist": "^3.10.5",
    "react-dnd-html5-backend": "^16.0.1",
    "tailwind-merge": "^2.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@boring-fixtures/default-plugin": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^2.15.4",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
