{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./.tsbuildinfo.server",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@hachej/boring-bash/modes": ["../boring-bash/src/modes/index.ts"],
      "@hachej/boring-sandbox/providers": ["../boring-sandbox/src/providers/index.ts"],
      "@hachej/boring-ui-plugin-cli/plugin-sources": ["../plugin-cli/src/server/pluginSources.ts"],
      "@hachej/boring-workspace/runtime-server": ["./src/server/runtimeBackend/defineRuntimeServerPlugin.ts"],
      "@hachej/boring-workspace/server": ["./src/server/index.ts"]
    }
  },
  "include": [
    "src/server/**/*",
    "src/app/server/**/*",
    "src/shared/**/*",
    "src/bridge-client/index.ts",
    "src/plugins/**/server/**/*",
    "src/plugins/**/agent/**/*",
    "src/plugins/**/shared/**/*",
    "src/plugins/**/constants.ts",
    "../boring-bash/src/modes/**/*",
    "../boring-sandbox/src/providers/**/*",
    "../boring-sandbox/src/shared/**/*",
    "../plugin-cli/src/server/pluginSources.ts",
    "../plugin-cli/src/manifest.ts"
  ],
  "files": [
    "src/shared/plugins/manifest.ts",
    "src/shared/plugins/runtimePluginTypes.ts",
    "src/shared/plugins/uiBridgeRegistry.ts"
  ],
  "exclude": ["node_modules", "dist", "src/app/front/**", "src/shared/plugins/**"]
}
