{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./.tsbuildinfo.server",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@hachej/boring-workspace/server": ["./src/server/index.ts"]
    }
  },
  "include": [
    "src/server/**/*",
    "src/app/server/**/*",
    "src/shared/**/*",
    "src/plugins/**/server/**/*",
    "src/plugins/**/agent/**/*",
    "src/plugins/**/shared/**/*",
    "src/plugins/**/constants.ts"
  ],
  "files": ["src/shared/plugins/manifest.ts", "src/shared/plugins/lifecycleBus.ts"],
  "exclude": ["node_modules", "dist", "src/app/front/**", "src/shared/plugins/**"]
}
