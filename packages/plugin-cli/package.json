{
  "name": "@hachej/boring-ui-plugin-cli",
  "version": "0.1.90",
  "description": "Slim boring-ui plugin authoring CLI for workspace runtimes.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "boring-ui-plugin": "./dist/bin.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-sources": {
      "import": "./dist/plugin-sources.js",
      "types": "./dist/plugin-sources.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hachej/boring-ui.git"
  },
  "homepage": "https://github.com/hachej/boring-ui"
}
