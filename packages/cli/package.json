    "@hachej/boring-ui-kit": "workspace:*",
    "@hachej/boring-workspace": "workspace:*",
    "@fastify/static": "^9.1.1",
    "@vitejs/plugin-react": "^4.0.0",
    "fastify": "^5.4.0",
    "lucide-react": "^1.8.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.4.0",
    "vitest": "^3.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  }
