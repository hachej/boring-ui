{
  "name": "@hachej/boring-ui-cli",
  "version": "0.1.64",
  "description": "Turn an agent into an app",
  "license": "MIT",
  "type": "module",
  "bin": {
    "boring-ui": "./dist/index.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "scripts": {
    "build": "tsup",
    "build:front": "vite build",
    "build:full": "node scripts/build-full.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^9.1.1",
    "@hachej/boring-agent": "workspace:*",
    "@hachej/boring-ask-user": "workspace:*",
    "@hachej/boring-bash": "workspace:*",
    "@hachej/boring-core": "workspace:*",
    "@hachej/boring-ui-kit": "workspace:*",
    "@hachej/boring-ui-plugin-cli": "workspace:*",
    "@hachej/boring-workspace": "workspace:*",
    "@vitejs/plugin-react": "^4.0.0",
    "cjs-module-lexer": "^2.0.0",
    "fastify": "^5.4.0",
    "lucide-react": "^1.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.4.0",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  }
}
