{
  "name": "@boring/agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Pane-embeddable coding agent with CLI. Ships direct/local/vercel-sandbox execution modes behind one interface.",
  "bin": {
    "boring-agent": "./dist/bin/boring-agent.js"
  },
  "exports": {
    ".": {
      "types": "./dist/front.d.ts",
      "import": "./dist/front.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./front": {
      "types": "./dist/front.d.ts",
      "import": "./dist/front.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/server/dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && pnpm run lint:invariants",
    "lint:invariants": "bash ../../scripts/check-invariants.sh .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  }
}
