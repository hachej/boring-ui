{
  "name": "@hachej/boring-agent",
  "version": "0.1.23",
  "type": "module",
  "license": "MIT",
  "description": "Pane-embeddable coding agent. Ships direct/local/vercel-sandbox execution modes behind one interface.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "exports": {
    ".": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./front": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./front/styles.css": "./dist/front/styles.css",
    "./eval": {
      "types": "./dist/eval/index.d.ts",
      "import": "./dist/eval/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/build-front-css.mjs && pnpm run build:assert",
    "build:dev": "{ [ -d '../ui/dist' ] || pnpm --filter @hachej/boring-ui-kit build; } && tsup --config tsup.dev.config.ts && node ./scripts/build-front-css.mjs",
    "build:assert": "node ./scripts/assert-build-artifacts.mjs",
    "dev": "tsx src/server/dev.ts",
    "test": "vitest run",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:regression": "vitest run src/server/__tests__/system-prompt-size.regression.test.ts",
    "test:watch": "vitest",
    "eval": "tsx ./scripts/eval.ts",
    "eval:provisioning": "tsx ./scripts/eval-provisioning-sdk.mts",
    "eval:provisioning:agent": "tsx ./scripts/eval-provisioning-agent.mts",
    "eval:provisioning:agent:vercel": "tsx ./scripts/eval-provisioning-agent-vercel.mts",
    "check:isolation": "tsx ./scripts/check-agent-isolation.ts",
    "pi-sdk:canary": "./scripts/pi-sdk-canary.sh",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && pnpm run lint:invariants",
    "lint:invariants": "bash ../../scripts/check-invariants.sh .",
    "clean": "rm -rf dist .tsbuildinfo",
    "smoke:vercel-sandbox": "tsx ./scripts/smoke-vercel-sandbox.mts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@hachej/boring-ui-kit": "workspace:*",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.75.5",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.0.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/sandbox": "2.0.0-beta.14",
    "ai": "^6.0.168",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "diff": "^9.0.0",
    "fastify": "^5.3.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.3",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.18.0",
    "postcss": "^8.5.13",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": ">=3.4.0 || >=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
