{
  "name": "@hachej/boring-agent",
  "version": "0.1.90",
  "type": "module",
  "license": "MIT",
  "description": "Pane-embeddable coding agent. Ships direct/local/vercel-sandbox execution modes behind one interface.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "exports": {
    ".": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./server/pi-session-readability": {
      "types": "./dist/server/pi-session-readability.d.ts",
      "import": "./dist/server/pi-session-readability.js",
      "default": "./dist/server/pi-session-readability.js"
    },
    "./server/worker": {
      "types": "./dist/server/worker/index.d.ts",
      "import": "./dist/server/worker/index.js",
      "default": "./dist/server/worker/index.js"
    },
    "./front": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./front/styles.css": "./dist/front/styles.css",
    "./eval": {
      "types": "./dist/eval/index.d.ts",
      "import": "./dist/eval/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/build-front-css.mjs && pnpm run build:assert",
    "build:dev": "{ [ -d '../ui/dist' ] || pnpm --filter @hachej/boring-ui-kit build; } && tsup --config tsup.dev.config.ts && node ./scripts/build-front-css.mjs",
    "build:assert": "node ./scripts/assert-build-artifacts.mjs",
    "dev": "tsx src/server/dev.ts",
    "test": "vitest run",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:chat-baseline": "node ./scripts/run-chat-baseline.mjs",
    "test:bombadil:chat": "node ./scripts/run-bombadil-chat.mjs",
    "test:bombadil:chat:nightly": "BOMBADIL_TIME_LIMIT=5m node ./scripts/run-bombadil-chat.mjs",
    "test:regression": "vitest run src/server/__tests__/system-prompt-size.regression.test.ts",
    "test:watch": "vitest",
    "eval": "tsx ./scripts/eval.ts",
    "eval:provisioning": "tsx ./scripts/eval-provisioning-sdk.mts",
    "eval:provisioning:agent": "tsx ./scripts/eval-provisioning-agent.mts",
    "eval:provisioning:agent:vercel": "tsx ./scripts/eval-provisioning-agent-vercel.mts",
    "check:isolation": "tsx ./scripts/check-agent-isolation.ts",
    "pi-sdk:canary": "./scripts/pi-sdk-canary.sh",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && pnpm run lint:invariants",
    "lint:invariants": "bash ../../scripts/check-invariants.sh .",
    "clean": "rm -rf dist .tsbuildinfo",
    "smoke:vercel-sandbox": "tsx ./scripts/smoke-vercel-sandbox.mts",
    "smoke:capability-readiness": "tsx ./scripts/smoke-capability-readiness.mts",
    "smoke:capability-readiness:vercel": "tsx ./scripts/smoke-capability-readiness-vercel.mts"
  },
  "dependencies": {
    "@hachej/boring-bash": "workspace:*",
    "@hachej/boring-sandbox": "workspace:*",
    "@hachej/boring-ui-kit": "workspace:*",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.80.7",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.101.1",
    "ai": "^7.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "diff": "^9.0.0",
    "fastify": "^5.9.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "shiki": "^4.3.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.6",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vercel/sandbox": "2.3.0",
    "@antithesishq/bombadil": "0.6.1",
    "@opentelemetry/api": "^1.9.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.4.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": ">=3.4.0 || >=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
