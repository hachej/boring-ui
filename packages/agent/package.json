{
  "name": "@boring/agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Pane-embeddable coding agent with CLI. Ships direct/local/vercel-sandbox execution modes behind one interface.",
  "bin": {
    "boring-agent": "./dist/bin/boring-agent.js"
  },
  "exports": {
    ".": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./front": {
      "types": "./dist/front/index.d.ts",
      "import": "./dist/front/index.js"
    },
    "./theme.css": "./dist/front/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && vite build && pnpm run build:assert",
    "build:assert": "node ./scripts/assert-build-artifacts.mjs",
    "dev": "tsx src/server/dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && pnpm run lint:invariants",
    "lint:invariants": "bash ../../scripts/check-invariants.sh .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@mariozechner/pi-coding-agent": "^0.67.6",
    "@tanstack/react-query": "^5.0.0",
    "@vercel/sandbox": "^1.10.0",
    "ai": "^6.0.168",
    "diff": "^9.0.0",
    "fastify": "^5.3.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
