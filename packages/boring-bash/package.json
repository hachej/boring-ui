{
  "name": "@hachej/boring-bash",
  "version": "0.1.90",
  "type": "module",
  "license": "MIT",
  "description": "Filesystem and shell binding contracts for Boring runtimes.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hachej/boring-ui"
  },
  "homepage": "https://github.com/hachej/boring-ui",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check:invariants": "node ./scripts/check-invariants.mjs",
    "lint": "pnpm run typecheck && pnpm run check:invariants",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.80.7"
  },
  "peerDependencies": {
    "@hachej/boring-agent": "workspace:*",
    "fastify": "^5.9.0"
  },
  "devDependencies": {
    "@hachej/boring-agent": "workspace:*",
    "@types/node": "^22.20.0",
    "fastify": "^5.9.0",
    "tsup": "^8.4.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
