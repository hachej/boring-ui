# Managed by Ansible — do not edit manually.

# Local administrative access.
local   all   all                                      peer

# App VM via Tailscale only. Do not replace with a broad CIDR.
host    {{ pg_database }}   {{ pg_database }}_runtime    {{ pg_app_tailscale_ip }}/32   scram-sha-256
host    {{ pg_database }}   {{ pg_database }}_migrator   {{ pg_app_tailscale_ip }}/32   scram-sha-256

{% if pg_monitor_password | default('') | length > 0 %}
# Local monitoring role.
host    {{ pg_database }}   {{ pg_database }}_monitor   127.0.0.1/32   scram-sha-256
{% endif %}
