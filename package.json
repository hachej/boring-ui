{
  "private": true,
  "name": "boring-ui-v2",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "visual:storybook": "pnpm storybook:build && pnpm exec playwright test -c .storybook/playwright.config.ts",
    "visual:storybook:update": "pnpm storybook:build && pnpm exec playwright test -c .storybook/playwright.config.ts --update-snapshots",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "lint:invariants": "pnpm --dir packages/agent run lint:invariants",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "ci:bundle-size": "pnpm --filter @boring/workspace run build && pnpm check:bundle-size",
    "test": "pnpm -r run test",
    "e2e": "pnpm exec playwright test -c e2e/playwright.config.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm lint:invariants && pnpm e2e",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-viewport": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/vite": "^4.1.14",
    "axe-core": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "storybook": "^8.6.14",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
