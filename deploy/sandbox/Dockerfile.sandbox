FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates unzip git gosu && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://bun.sh/install | bash && \
    ln -s /root/.bun/bin/bun /usr/local/bin/bun && \
    ln -s /root/.bun/bin/bunx /usr/local/bin/bunx && \
    /root/.bun/bin/bun add -g @anthropic-ai/claude-code && \
    ln -s /root/.bun/bin/claude /usr/local/bin/claude && \
    ln -s /root/.bun/bin/bun /usr/local/bin/node && \
    chmod o+rx /root && chmod -R o+rX /root/.bun

# Create non-root user (claude refuses --dangerously-skip-permissions as root)
RUN useradd -m -d /home/sprite -s /bin/bash sprite

WORKDIR /home/sprite/app
COPY artifacts/boring-macro-bundle.tar.gz /tmp/bundle.tar.gz
RUN tar -xzf /tmp/bundle.tar.gz -C /home/sprite/app && rm /tmp/bundle.tar.gz
RUN pip install --no-cache-dir --force-reinstall wheels/boring_macro-*.whl
RUN chown -R sprite:sprite /home/sprite

COPY deploy/sandbox/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
