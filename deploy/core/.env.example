# --- core mode compose env template ---
# Usage:
#   cp deploy/core/.env.example .env.core
#   docker compose --env-file .env.core -f deploy/core/docker-compose.yml up --build backend frontend

# Backend/control-plane
CONTROL_PLANE_PROVIDER=neon
CONTROL_PLANE_APP_ID=boring-ui

# Neon (preferred)
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<id>-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require
NEON_AUTH_BASE_URL=https://ep-<id>.neonauth.c-2.eu-central-1.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://ep-<id>.neonauth.c-2.eu-central-1.aws.neon.tech/neondb/auth/.well-known/jwks.json

# Supabase (legacy — use if CONTROL_PLANE_PROVIDER=supabase)
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_JWT_SECRET=<jwt-secret>
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

BORING_SETTINGS_KEY=<32-byte-settings-key>
BORING_UI_SESSION_SECRET=<session-signing-secret>
# Required when backend stream/chat routes are enabled.
ANTHROPIC_API_KEY=

# Ports
BORING_UI_BACKEND_PORT=8000
BORING_UI_FRONTEND_PORT=5173

# Frontend routing
CORE_VITE_API_URL=http://127.0.0.1:5173
CORE_VITE_PROXY_API_TARGET=http://backend:8000

# Core profile defaults:
# - pi-lightningfs (recommended)
# - pi-cheerpx
# - pi-httpfs
CORE_UI_PROFILE=pi-lightningfs

# Optional explicit overrides (usually leave unset when CORE_UI_PROFILE is set)
CORE_VITE_AGENT_RAIL_MODE=pi
CORE_VITE_DATA_BACKEND=lightningfs
CORE_VITE_LIGHTNINGFS_NAME=boring-fs

# Optional cheerpx tuning (used with CORE_UI_PROFILE=pi-cheerpx)
CORE_VITE_CHEERPX_WORKSPACE_ROOT=
CORE_VITE_CHEERPX_PRIMARY_DISK_URL=
CORE_VITE_CHEERPX_OVERLAY_NAME=
CORE_VITE_CHEERPX_ESM_URL=

# Onboarding UX
CORE_VITE_CONTROL_PLANE_ONBOARDING=false

# PI agent provider keys (dev only — seeded into browser IndexedDB on startup).
# In production, users enter keys manually via the UI prompt.
# CORE_VITE_PI_OPENAI_API_KEY=
# CORE_VITE_PI_ANTHROPIC_API_KEY=
# CORE_VITE_PI_GOOGLE_API_KEY=
