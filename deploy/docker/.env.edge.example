# --- edge mode compose env template ---
# Usage:
#   cp deploy/docker/.env.edge.example .env.edge
#   docker compose --env-file .env.edge -f deploy/docker/docker-compose.sandbox.yml up --build sandbox frontend

# Backend/control-plane
CONTROL_PLANE_PROVIDER=supabase
CONTROL_PLANE_APP_ID=boring-ui
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>
SUPABASE_DB_URL=postgresql://postgres.<project>:<password>@<host>:5432/postgres
BORING_SETTINGS_KEY=<32-byte-settings-key>
BORING_UI_SESSION_SECRET=<session-signing-secret>

# Ports
BORING_UI_EDGE_BACKEND_PORT=18001
BORING_UI_EDGE_PORT=8081
BORING_UI_EDGE_FRONTEND_PORT=5174

# Edge companion/gateway wiring
EDGE_COMPANION_URL=/companion
EDGE_VITE_API_URL=http://127.0.0.1:5174
EDGE_VITE_PROXY_API_TARGET=http://backend:8000
EDGE_VITE_COMPANION_PROXY_TARGET=http://sandbox:8080

# Edge profile defaults:
# - companion-httpfs (recommended)
EDGE_UI_PROFILE=companion-httpfs

# Optional explicit overrides (usually leave unset when EDGE_UI_PROFILE is set)
EDGE_VITE_AGENT_RAIL_MODE=companion
EDGE_VITE_DATA_BACKEND=http
EDGE_VITE_CONTROL_PLANE_ONBOARDING=true

# Sandbox runtime env
BM_CHAT_PROVIDER=companion
BM_COMPANION_AUTOSTART=true
BM_CLICKHOUSE_URL=
ANTHROPIC_API_KEY=
